# Database Configuration (Prisma 7)
DATABASE_URL = "postgresql://user:password@localhost:5432/database?schema=pieia"

# Core IAM - Supabase del CORE/wabee (COMPARTIDO, para Supabase Auth). Apunta al proyecto
# del core, no al propio de PIEIA. NO se usa para Storage.
SUPABASE_URL = "https://your-core-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "your-core-service-role-key"

# Almacenamiento de entregables en Supabase Storage. OBLIGATORIO en produccion: el disco de
# Render/Railway es efimero y se borra en cada deploy. Si las tres variables estan definidas
# se usa Supabase; si no, disco local (backend/uploads) para dev.
# IMPORTANTE: estas apuntan al proyecto Supabase PROPIO de PIEIA (ref dnxicscudpgqcfdhdqgd,
# el mismo de DATABASE_URL), NO al del core (no tenemos acceso a crear buckets ahi).
# Pasos: en TU proyecto Supabase > Storage crea un bucket PRIVADO (ej. "pieia-entregables"),
# copia su URL y su service_role key aqui, y migra lo ya subido:
#   node scripts/migrar-storage-supabase.js
STORAGE_SUPABASE_URL = "https://dnxicscudpgqcfdhdqgd.supabase.co"
STORAGE_SUPABASE_KEY = "your-pieia-project-service-role-key"
SUPABASE_BUCKET = ""

# Core IAM - Security
JWT_SECRET = "your-super-secret-key"

# Core IAM - Billing (Stripe)
STRIPE_SECRET_KEY = "sk_test_..."
STRIPE_WEBHOOK_SECRET = "whsec_..."

# Application Settings
FRONTEND_URL = "http://localhost:3000"

# Observabilidad — Sentry (RNF-08). Sin DSN, Sentry queda desactivado (no-op).
SENTRY_DSN = ""
SENTRY_TRACES_SAMPLE_RATE = "0.1"
SENTRY_RELEASE = ""
# Logs estructurados: debug | info | warn | error. En NODE_ENV=production se emiten en JSON.
LOG_LEVEL = "info"
NODE_ENV = "development"

# Alertas de costo de IA por umbral (RF-H04). Valor 0 o vacío = alerta desactivada.
ALERTA_COSTO_PROYECTO_USD = "0"
ALERTA_COSTO_MENSUAL_USD = "0"

# Frontend (Vite) — definir en frontend/.env:
# VITE_SENTRY_DSN, VITE_SENTRY_TRACES_SAMPLE_RATE, VITE_SENTRY_RELEASE
